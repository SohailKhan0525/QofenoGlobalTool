# ==========================================
# Qofeno — Production Environment Example
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ==========================================

# ── Appwrite (Server-side only — used in Appwrite Functions) ──────────────────
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_API_KEY=your_appwrite_api_key_here
DATABASE_ID=qofeno_db
BUCKET_INPUTS=tool_inputs
BUCKET_OUTPUTS=tool_outputs
APPWRITE_OAUTH_REDIRECT=https://fra.cloud.appwrite.io/v1/account/sessions/oauth2/callback/google/your_project_id_here

# ── Cloudflare Pages Deployment ───────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_KEY=your_cloudflare_api_token
CLOUDFLARE_PAGES_PROJECT=qofeno-labs
CLOUDFLARE_PAGES_DOMAIN=qofeno-labs.pages.dev

# ── PayPal (SERVER ONLY — never expose secret to browser) ────────────────────
PAYPAL_CLIENT_ID=your_paypal_live_client_id
PAYPAL_SECRET=your_paypal_live_secret
PAYPAL_MODE=live
# Register paypal-webhook Appwrite Function URL in PayPal Console, paste ID here:
PAYPAL_WEBHOOK_ID=

# ── Third-party Integrations ──────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_secret

# ==========================================
# VITE_ vars — safe to expose to browser
# ==========================================

VITE_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id_here
VITE_APPWRITE_DATABASE_ID=qofeno_db

# ── PayPal (FRONTEND — client ID only, NEVER secret) ─────────────────────────
VITE_PAYPAL_CLIENT_ID=your_paypal_live_client_id
VITE_PAYPAL_MODE=live

# Create subscription plans in PayPal Dashboard → Products → Plans
# https://developer.paypal.com/dashboard/products
VITE_PAYPAL_PLAN_ID_MONTHLY=
VITE_PAYPAL_PLAN_ID_YEARLY=
VITE_PAYPAL_TEAMS_PLAN_ID_MONTHLY=
VITE_PAYPAL_TEAMS_PLAN_ID_YEARLY=

# ── Appwrite Function IDs ─────────────────────────────────────────────────────
# Developer / Text Tools
VITE_APPWRITE_FUNCTION_JSON_FORMATTER_ID=
VITE_APPWRITE_FUNCTION_WORD_COUNTER_ID=
VITE_APPWRITE_FUNCTION_BASE64_ENCODER_ID=
VITE_APPWRITE_FUNCTION_TEXT_CASE_CONVERTER_ID=
VITE_APPWRITE_FUNCTION_TRACK_EVENT_ID=
VITE_APPWRITE_FUNCTION_CONTACT_FORM_ID=

# Platform / Utility Functions
VITE_APPWRITE_FUNCTION_CREATE_DOWNLOAD_LINK_ID=
VITE_APPWRITE_FUNCTION_AUTH_WEBHOOK_ID=
VITE_APPWRITE_FUNCTION_PAYMENT_WEBHOOK_ID=

# FREE PDF Tools
VITE_APPWRITE_FUNCTION_PDF_COMPRESSOR_ID=
VITE_APPWRITE_FUNCTION_PDF_MERGER_ID=
VITE_APPWRITE_FUNCTION_PDF_SPLITTER_ID=
VITE_APPWRITE_FUNCTION_PDF_ROTATE_ID=
VITE_APPWRITE_FUNCTION_PDF_TO_JPG_ID=
VITE_APPWRITE_FUNCTION_JPG_TO_PDF_ID=
VITE_APPWRITE_FUNCTION_PDF_PAGE_NUMBERS_ID=
VITE_APPWRITE_FUNCTION_PDF_TO_TEXT_ID=
VITE_APPWRITE_FUNCTION_PDF_WORD_COUNT_ID=
VITE_APPWRITE_FUNCTION_PDF_METADATA_VIEWER_ID=

# PRO PDF Tools
VITE_APPWRITE_FUNCTION_PDF_TO_WORD_ID=
VITE_APPWRITE_FUNCTION_PDF_WATERMARK_ID=
VITE_APPWRITE_FUNCTION_PDF_PROTECT_ID=
VITE_APPWRITE_FUNCTION_PDF_OCR_ID=
VITE_APPWRITE_FUNCTION_PDF_UNLOCK_ID=
VITE_APPWRITE_FUNCTION_PDF_FLATTEN_ID=
VITE_APPWRITE_FUNCTION_PDF_THUMBNAIL_ID=
VITE_APPWRITE_FUNCTION_PDF_REPAIR_ID=
VITE_APPWRITE_FUNCTION_PDF_REDACT_ID=
VITE_APPWRITE_FUNCTION_PDF_SIGN_ID=
VITE_APPWRITE_FUNCTION_PDF_CROP_ID=
VITE_APPWRITE_FUNCTION_PDF_COMPARE_ID=
VITE_APPWRITE_FUNCTION_PDF_TO_EXCEL_ID=
VITE_APPWRITE_FUNCTION_PDF_TO_POWERPOINT_ID=
VITE_APPWRITE_FUNCTION_PDF_TO_HTML_ID=
VITE_APPWRITE_FUNCTION_WORD_TO_PDF_ID=
VITE_APPWRITE_FUNCTION_EXCEL_TO_PDF_ID=
VITE_APPWRITE_FUNCTION_POWERPOINT_TO_PDF_ID=

# Image Tools
VITE_APPWRITE_FUNCTION_IMAGE_RESIZER_ID=
VITE_APPWRITE_FUNCTION_IMAGE_COMPRESSOR_ID=
VITE_APPWRITE_FUNCTION_IMAGE_CONVERTER_ID=
VITE_APPWRITE_FUNCTION_IMAGE_BG_REMOVER_ID=

# Video Tools
VITE_APPWRITE_FUNCTION_VIDEO_COMPRESSOR_ID=
VITE_APPWRITE_FUNCTION_VIDEO_TRIMMER_ID=

# ── NEXT_PUBLIC_ vars (for Next.js compatibility if migrating) ────────────────
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_APPWRITE_DATABASE_ID=qofeno_db
NEXT_PUBLIC_OAUTH_REDIRECT=https://fra.cloud.appwrite.io/v1/account/sessions/oauth2/callback/google/your_project_id_here

# Collection & Bucket IDs
NEXT_PUBLIC_COL_USERS_META=users_meta
NEXT_PUBLIC_COL_TOOLS=tools
NEXT_PUBLIC_COL_EXECUTIONS=tool_executions
NEXT_PUBLIC_COL_VIEWS=tool_views
NEXT_PUBLIC_COL_LIKES=tool_likes
NEXT_PUBLIC_COL_RECENTLY_VIEWED=recently_viewed
NEXT_PUBLIC_COL_SUBSCRIPTIONS=subscriptions
NEXT_PUBLIC_COL_WHATS_NEW=whats_new
NEXT_PUBLIC_COL_CONTACT=contact_messages
NEXT_PUBLIC_BUCKET_INPUTS=tool_inputs
NEXT_PUBLIC_BUCKET_OUTPUTS=tool_outputs
